# Токен бота от @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Ваш Telegram ID (узнать у @userinfobot)
ADMIN_ID=YOUR_TELEGRAM_ID

# Режим работы: "webhook" или "polling"
MODE=polling

# URL для webhook (нужен для режима webhook)
# Пример: https://your-app-name.onrender.com
WEBHOOK_URL=

# Секретный токен для webhook (любой случайный набор символов)
WEBHOOK_SECRET=your_secret_token_here

# URL API сервера (для миниаппа)
# Пример: https://your-app-name.onrender.com
API_URL=http://localhost:5000
